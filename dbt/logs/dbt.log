    create  table
      "pipeline"."main"."dim_ticker__dbt_tmp"
  
    as (
      -- Dimension: unique tickers with surrogate keys
WITH stg AS (
    SELECT * FROM "pipeline"."main"."stg_tickers"
)
SELECT
    ticker_sk,
    symbol,
    asset_type,
    market_cap_rank,
    CASE
        WHEN market_cap_rank <= 10 THEN 'Top 10'
        WHEN market_cap_rank <= 50 THEN 'Top 50'
