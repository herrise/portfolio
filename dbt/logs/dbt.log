        WHEN market_cap_rank <= 10 THEN 'Top 10'
        WHEN market_cap_rank <= 50 THEN 'Top 50'
        WHEN market_cap_rank <= 100 THEN 'Top 100'
        ELSE 'Other'
    END AS rank_tier
FROM stg
    );
  
  
